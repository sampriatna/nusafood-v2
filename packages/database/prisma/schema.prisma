generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: pooler (6543) di DATABASE_URL; session/direct di DIRECT_URL untuk migrate
  directUrl = env("DIRECT_URL")
}

enum StaffRole {
  STAFF
  LEADER
  ADMIN
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum TaskStatus {
  CREATED
  SENT
  WA_FAILED
  OPEN
  OPENED
  SUBMITTED
  RESUBMITTED
  WAITING_VERIFICATION
  DONE
  VERIFIED
  REVISI
  REVISION
  REVISION_REQUESTED
  LATE
}

enum TaskPriority {
  Low
  Medium
  High
  Urgent
}

enum RepeatType {
  daily
  weekdays
  weekly
  monthly
  custom
}

enum ChecklistReportStatus {
  OPEN
  SUBMITTED
  DONE
  REVISI
  LATE
}

enum SyncStatus {
  success
  partial
  failed
}

enum ReportTemplateKind {
  daily_required
  special_task
  issue_quick
}

enum ReportConditionStatus {
  aman
  kendala_ringan
  follow_up_leader
  perlu_belanja
}

enum StaffReportValidationStatus {
  valid
  revisi
  tidak_valid
  manipulasi
}

enum LeaderMonitorKind {
  opening_control
  jam_ramai_control
  spot_check_area
  closing_control
  issue_log
}

enum LeaderMonitorStatus {
  aman
  ada_catatan
  tidak_sesuai
}

enum LeaderFollowUpStatus {
  open
  on_progress
  selesai
}

enum LeaderPhotoMode {
  required
  optional
  required_if_issue
}

model Outlet {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  areas                   Area[]
  staff                   Staff[]
  tasks                   Task[]
  recurringTemplates      RecurringTemplate[]
  checklistTemplates      ChecklistTemplate[]
  checklistReports        ChecklistReport[]
  reportTemplates         ReportTemplate[]
  dailyReportSubmissions  DailyReportSubmission[]

  @@map("outlets")
}

model Area {
  id        String   @id @default(uuid()) @db.Uuid
  outletId  String?  @map("outlet_id") @db.Uuid
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet             Outlet?             @relation(fields: [outletId], references: [id])
  staff              Staff[]
  tasks              Task[]
  recurringTemplates RecurringTemplate[]
  checklistTemplates ChecklistTemplate[]
  checklistReports   ChecklistReport[]

  @@unique([outletId, name])
  @@map("areas")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tasks              Task[]
  recurringTemplates RecurringTemplate[]

  @@map("categories")
}

model Staff {
  id           String      @id @default(uuid()) @db.Uuid
  staffId      String      @unique @map("staff_id") @db.VarChar(50)
  name         String      @db.VarChar(200)
  position     String?     @db.VarChar(100)
  outletId     String      @map("outlet_id") @db.Uuid
  areaId       String?     @map("area_id") @db.Uuid
  waNumber     String      @map("wa_number") @db.VarChar(20)
  role         StaffRole   @default(STAFF)
  status       StaffStatus @default(ACTIVE)
  loginEnabled Boolean     @default(false) @map("login_enabled")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet                 Outlet                 @relation(fields: [outletId], references: [id])
  area                   Area?                  @relation(fields: [areaId], references: [id])
  userAccount            UserAccount?
  tasks                  Task[]
  recurringTemplates     RecurringTemplate[]
  staffReportLinks       StaffReportLink[]
  dailyReportSubmissions DailyReportSubmission[]

  @@index([outletId], map: "idx_staff_outlet")
  @@index([status], map: "idx_staff_status")
  @@index([waNumber], map: "idx_staff_wa")
  @@map("staff")
}

model UserAccount {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.VarChar(50)
  staffId       String?   @unique @map("staff_id") @db.VarChar(50)
  username      String    @unique @db.VarChar(100)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  role          StaffRole
  /// Owner app-level (bukan enum StaffRole) — akses penuh sensitif
  isOwner       Boolean   @default(false) @map("is_owner")
  /// ADMIN/HR permission eksplisit untuk approve SP (OWNER selalu boleh)
  canApproveSp  Boolean   @default(false) @map("can_approve_sp")
  loginEnabled  Boolean   @default(true) @map("login_enabled")
  lastLogin     DateTime? @map("last_login") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  staff Staff? @relation(fields: [staffId], references: [staffId])

  @@map("user_accounts")
}

model Task {
  id                  String       @id @default(uuid()) @db.Uuid
  taskId              String       @unique @map("task_id") @db.VarChar(50)
  token               String       @db.VarChar(64)
  createdBy           String?      @map("created_by") @db.VarChar(200)
  outletId            String       @map("outlet_id") @db.Uuid
  areaId              String?      @map("area_id") @db.Uuid
  categoryId          String?      @map("category_id") @db.Uuid
  outletName          String?      @map("outlet_name") @db.VarChar(100)
  areaName            String?      @map("area_name") @db.VarChar(100)
  categoryName        String?      @map("category_name") @db.VarChar(100)
  taskTitle           String       @map("task_title") @db.VarChar(500)
  taskDescription     String?      @map("task_description")
  priority            TaskPriority @default(Medium)
  picName             String       @map("pic_name") @db.VarChar(200)
  picWa               String       @map("pic_wa") @db.VarChar(20)
  staffId             String?      @map("staff_id") @db.VarChar(50)
  deadline            DateTime     @db.Timestamptz(6)
  beforePhotoUrl      String?      @map("before_photo_url")
  status              TaskStatus   @default(CREATED)
  reportLink          String?      @map("report_link")
  waSentAt            DateTime?    @map("wa_sent_at") @db.Timestamptz(6)
  openedAt            DateTime?    @map("opened_at") @db.Timestamptz(6)
  submittedAt         DateTime?    @map("submitted_at") @db.Timestamptz(6)
  afterPhotoUrl       String?      @map("after_photo_url")
  staffNote           String?      @map("staff_note")
  leaderVerification  String?      @map("leader_verification")
  verifiedBy          String?      @map("verified_by") @db.VarChar(200)
  verifiedAt          DateTime?    @map("verified_at") @db.Timestamptz(6)
  finalStatus         String?      @map("final_status") @db.VarChar(50)
  isLate              Boolean      @default(false) @map("is_late")
  durationMinutes     Int?         @map("duration_minutes")
  checklistMode       Boolean      @default(false) @map("checklist_mode")
  recurringTemplateId String?      @map("recurring_template_id") @db.VarChar(50)
  sourceVersion       String       @default("v2") @map("source_version") @db.VarChar(10)
  gasSyncedAt         DateTime?    @map("gas_synced_at") @db.Timestamptz(6)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet           Outlet            @relation(fields: [outletId], references: [id])
  area             Area?             @relation(fields: [areaId], references: [id])
  category         Category?         @relation(fields: [categoryId], references: [id])
  staff            Staff?            @relation(fields: [staffId], references: [staffId])
  checklistReports ChecklistReport[]

  @@index([status], map: "idx_tasks_status")
  @@index([deadline], map: "idx_tasks_deadline")
  @@index([outletId], map: "idx_tasks_outlet")
  @@index([taskId, token], map: "idx_tasks_token")
  @@index([picWa], map: "idx_tasks_pic")
  @@index([createdAt(sort: Desc)], map: "idx_tasks_created")
  @@map("tasks")
}

model RecurringTemplate {
  id               String     @id @default(uuid()) @db.Uuid
  templateId       String     @unique @map("template_id") @db.VarChar(50)
  templateName     String     @map("template_name") @db.VarChar(200)
  outletId         String     @map("outlet_id") @db.Uuid
  areaId           String?    @map("area_id") @db.Uuid
  categoryId       String?    @map("category_id") @db.Uuid
  picName          String     @map("pic_name") @db.VarChar(200)
  picWa            String     @map("pic_wa") @db.VarChar(20)
  staffId          String?    @map("staff_id") @db.VarChar(50)
  taskTitle        String     @map("task_title") @db.VarChar(500)
  taskDescription  String?    @map("task_description")
  repeatType       RepeatType @default(daily) @map("repeat_type")
  repeatDays       String[]   @map("repeat_days")
  repeatTime       DateTime   @map("repeat_time") @db.Time(6)
  deadlineTime     DateTime   @map("deadline_time") @db.Time(6)
  requiresPhoto    Boolean    @default(true) @map("requires_photo")
  activeStatus     Boolean    @default(true) @map("active_status")
  templateVersion  Int        @default(1) @map("template_version")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet   Outlet    @relation(fields: [outletId], references: [id])
  area     Area?     @relation(fields: [areaId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  staff    Staff?    @relation(fields: [staffId], references: [staffId])

  @@map("recurring_templates")
}

model ChecklistTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  templateId     String   @unique @map("template_id") @db.VarChar(50)
  templateName   String   @map("template_name") @db.VarChar(200)
  outletId       String   @map("outlet_id") @db.Uuid
  areaId         String?  @map("area_id") @db.Uuid
  taskTitle      String?  @map("task_title") @db.VarChar(500)
  checklistTitle String   @map("checklist_title") @db.VarChar(500)
  picName        String?  @map("pic_name") @db.VarChar(200)
  picWa          String?  @map("pic_wa") @db.VarChar(20)
  requiresPhoto  Boolean  @default(false) @map("requires_photo")
  activeStatus   Boolean  @default(true) @map("active_status")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet  Outlet           @relation(fields: [outletId], references: [id])
  area    Area?            @relation(fields: [areaId], references: [id])
  items   ChecklistItem[]
  reports ChecklistReport[]

  @@map("checklist_templates")
}

model ChecklistItem {
  id              String   @id @default(uuid()) @db.Uuid
  checklistItemId String   @unique @map("checklist_item_id") @db.VarChar(50)
  templateId      String   @map("template_id") @db.VarChar(50)
  itemOrder       Int      @map("item_order")
  itemText        String   @map("item_text")
  requiresPhoto   Boolean  @default(false) @map("requires_photo")
  isRequired      Boolean  @default(true) @map("is_required")
  activeStatus    Boolean  @default(true) @map("active_status")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  template    ChecklistTemplate     @relation(fields: [templateId], references: [templateId])
  reportItems ChecklistReportItem[]

  @@unique([templateId, itemOrder])
  @@map("checklist_items")
}

model ChecklistReport {
  id             String                @id @default(uuid()) @db.Uuid
  reportId       String                @unique @map("report_id") @db.VarChar(50)
  taskId         String?               @map("task_id") @db.VarChar(50)
  templateId     String                @map("template_id") @db.VarChar(50)
  token          String                @db.VarChar(64)
  picName        String                @map("pic_name") @db.VarChar(200)
  picWa          String                @map("pic_wa") @db.VarChar(20)
  outletId       String?               @map("outlet_id") @db.Uuid
  areaId         String?               @map("area_id") @db.Uuid
  reportDate     DateTime              @map("report_date") @db.Date
  deadline       DateTime              @db.Timestamptz(6)
  checklistTitle String?               @map("checklist_title") @db.VarChar(500)
  status         ChecklistReportStatus @default(OPEN)
  submittedAt    DateTime?             @map("submitted_at") @db.Timestamptz(6)
  staffNote      String?               @map("staff_note")
  afterPhotoUrl  String?               @map("after_photo_url")
  verifiedBy     String?               @map("verified_by") @db.VarChar(200)
  verifiedAt     DateTime?             @map("verified_at") @db.Timestamptz(6)
  revisionNote   String?               @map("revision_note")
  revisionCount  Int                   @default(0) @map("revision_count")
  isLate         Boolean               @default(false) @map("is_late")
  sourceVersion  String                @default("v2") @map("source_version") @db.VarChar(10)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  task     Task?                 @relation(fields: [taskId], references: [taskId])
  template ChecklistTemplate     @relation(fields: [templateId], references: [templateId])
  outlet   Outlet?               @relation(fields: [outletId], references: [id])
  area     Area?                 @relation(fields: [areaId], references: [id])
  items    ChecklistReportItem[]

  @@index([taskId, token], map: "idx_checklist_reports_token")
  @@index([status], map: "idx_checklist_reports_status")
  @@map("checklist_reports")
}

model ChecklistReportItem {
  id              String    @id @default(uuid()) @db.Uuid
  reportItemId    String    @unique @map("report_item_id") @db.VarChar(50)
  reportId        String    @map("report_id") @db.VarChar(50)
  checklistItemId String    @map("checklist_item_id") @db.VarChar(50)
  isChecked       Boolean   @default(false) @map("is_checked")
  photoUrl        String?   @map("photo_url")
  checkedAt       DateTime? @map("checked_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  report ChecklistReport @relation(fields: [reportId], references: [reportId])
  item   ChecklistItem   @relation(fields: [checklistItemId], references: [checklistItemId])

  @@unique([reportId, checklistItemId])
  @@map("checklist_report_items")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(50)
  action     String   @db.VarChar(100)
  actorType  String   @map("actor_type") @db.VarChar(20)
  actorId    String?  @map("actor_id") @db.VarChar(100)
  actorName  String?  @map("actor_name") @db.VarChar(200)
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.Inet
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([createdAt(sort: Desc)], map: "idx_audit_created")
  @@map("audit_logs")
}

model SyncLog {
  id           String      @id @default(uuid()) @db.Uuid
  operation    String      @db.VarChar(100)
  entityType   String      @map("entity_type") @db.VarChar(50)
  entityId     String?     @map("entity_id") @db.VarChar(50)
  v1Status     SyncStatus? @map("v1_status")
  v2Status     SyncStatus? @map("v2_status")
  v1Response   Json?       @map("v1_response")
  v2Response   Json?       @map("v2_response")
  errorMessage String?     @map("error_message")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId], map: "idx_sync_logs_entity")
  @@map("sync_logs")
}

/// Daily Activity SOP — link pribadi staff (/r/[token|short_code])
model StaffReportLink {
  id        String    @id @default(uuid()) @db.Uuid
  staffId   String    @map("staff_id") @db.VarChar(50)
  token     String    @unique @db.VarChar(128)
  shortCode String    @unique @map("short_code") @db.VarChar(48)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  staff Staff @relation(fields: [staffId], references: [staffId])

  @@index([staffId], map: "idx_staff_report_links_staff")
  @@index([isActive], map: "idx_staff_report_links_active")
  @@map("staff_report_links")
}

/// Template kegiatan standar (SOP) — terpisah dari checklist_templates task
model ReportTemplate {
  id               String             @id @default(uuid()) @db.Uuid
  code             String             @unique @db.VarChar(50)
  title            String             @db.VarChar(200)
  category         String             @default("General") @db.VarChar(50)
  outletId         String?            @map("outlet_id") @db.Uuid
  positionGroup    String?            @map("position_group") @db.VarChar(100)
  standardResult   String             @map("standard_result")
  description      String?
  requiresPhoto    Boolean            @default(false) @map("requires_photo")
  isRequiredDaily  Boolean            @default(false) @map("is_required_daily")
  kind             ReportTemplateKind @default(daily_required)
  targetTimeStart  DateTime?          @map("target_time_start") @db.Time(6)
  targetTimeEnd    DateTime?          @map("target_time_end") @db.Time(6)
  active           Boolean            @default(true)
  sortOrder        Int                @default(10) @map("sort_order")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet      Outlet?                        @relation(fields: [outletId], references: [id])
  items       ReportTemplateChecklistItem[]
  submissions DailyReportSubmission[]

  @@index([active, sortOrder], map: "idx_report_templates_active")
  @@map("report_templates")
}

model ReportTemplateChecklistItem {
  id               String   @id @default(uuid()) @db.Uuid
  reportTemplateId String   @map("report_template_id") @db.Uuid
  itemText         String   @map("item_text") @db.VarChar(500)
  isRequired       Boolean  @default(true) @map("is_required")
  sortOrder        Int      @default(1) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  template ReportTemplate               @relation(fields: [reportTemplateId], references: [id], onDelete: Cascade)
  answers  DailyReportChecklistAnswer[]

  @@index([reportTemplateId, sortOrder], map: "idx_rtci_template")
  @@map("report_template_checklist_items")
}

model DailyReportSubmission {
  id               String                @id @default(uuid()) @db.Uuid
  staffId          String                @map("staff_id") @db.VarChar(50)
  outletId         String                @map("outlet_id") @db.Uuid
  reportTemplateId String                @map("report_template_id") @db.Uuid
  reportDate       DateTime              @map("report_date") @db.Date
  statusCondition  ReportConditionStatus @map("status_condition")
  note             String?
  photoUrl         String?               @map("photo_url")
  submittedAt      DateTime              @default(now()) @map("submitted_at") @db.Timestamptz(6)
  leaderValidation StaffReportValidationStatus? @map("leader_validation")
  leaderValidationNote String?           @map("leader_validation_note")
  leaderValidatedAt DateTime?            @map("leader_validated_at") @db.Timestamptz(6)
  leaderValidatedBy String?              @map("leader_validated_by") @db.VarChar(50)
  leaderValidatedByName String?          @map("leader_validated_by_name") @db.VarChar(200)
  leaderValidationPhotoUrl String?       @map("leader_validation_photo_url")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  staff    Staff                        @relation(fields: [staffId], references: [staffId])
  outlet   Outlet                       @relation(fields: [outletId], references: [id])
  template ReportTemplate               @relation(fields: [reportTemplateId], references: [id])
  answers  DailyReportChecklistAnswer[]

  @@unique([staffId, reportTemplateId, reportDate])
  @@index([reportDate], map: "idx_daily_report_submissions_date")
  @@map("daily_report_submissions")
}

model DailyReportChecklistAnswer {
  id              String   @id @default(uuid()) @db.Uuid
  submissionId    String   @map("submission_id") @db.Uuid
  checklistItemId String   @map("checklist_item_id") @db.Uuid
  checked         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  submission DailyReportSubmission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  item       ReportTemplateChecklistItem @relation(fields: [checklistItemId], references: [id])

  @@unique([submissionId, checklistItemId])
  @@map("daily_report_checklist_answers")
}

/// Leader Monitoring — checklist keliling leader (di atas daily report staff)
model LeaderMonitorTemplate {
  id              String           @id @default(uuid()) @db.Uuid
  kind            LeaderMonitorKind
  title           String           @db.VarChar(500)
  menuLabel       String           @map("menu_label") @db.VarChar(200)
  description     String           @default("")
  standardResult  String           @map("standard_result")
  outletCode      String?          @map("outlet_code") @db.VarChar(50)
  targetTimeStart String?          @map("target_time_start") @db.VarChar(10)
  targetTimeEnd   String?          @map("target_time_end") @db.VarChar(10)
  photoMode       LeaderPhotoMode  @default(required) @map("photo_mode")
  checklist       Json             @default("[]")
  active          Boolean          @default(true)
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  submissions LeaderMonitorSubmission[]

  @@index([active, sortOrder], map: "idx_leader_monitor_templates_active")
  @@map("leader_monitor_templates")
}

model LeaderMonitorSubmission {
  id                 String                     @id @default(uuid()) @db.Uuid
  templateId         String                     @map("template_id") @db.Uuid
  kind               LeaderMonitorKind
  reportDate         DateTime                   @map("report_date") @db.Date
  outletCode         String                     @map("outlet_code") @db.VarChar(50)
  shift              String                     @db.VarChar(50)
  leaderId           String                     @map("leader_id") @db.VarChar(50)
  leaderName         String                     @map("leader_name") @db.VarChar(200)
  area               String                     @db.VarChar(100)
  status             LeaderMonitorStatus
  scoreTotal         Int                        @map("score_total")
  scoreMax           Int                        @map("score_max")
  checklistScores    Json                       @default("[]") @map("checklist_scores")
  relatedStaffIds    Json                       @default("[]") @map("related_staff_ids")
  relatedStaffNames  String                     @default("") @map("related_staff_names")
  problemNote        String                     @default("") @map("problem_note")
  fixInstruction     String                     @default("") @map("fix_instruction")
  fixDeadline        String?                    @map("fix_deadline") @db.VarChar(20)
  photoUrl           String?                    @map("photo_url")
  followUpStatus     LeaderFollowUpStatus       @default(open) @map("follow_up_status")
  staffSubmissionId  String?                    @map("staff_submission_id") @db.Uuid
  staffValidation    StaffReportValidationStatus? @map("staff_validation")
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  template LeaderMonitorTemplate @relation(fields: [templateId], references: [id])

  @@index([reportDate, outletCode], map: "idx_leader_monitor_submissions_date_outlet")
  @@map("leader_monitor_submissions")
}

/* ─── Disciplinary / Teguran Center ─── */

enum DisciplinaryLetterType {
  TEGURAN
  PERINGATAN
}

enum DisciplinaryLetterStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  SENT
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
}

enum DisciplinarySourceType {
  TASK_LATE
  TASK_INCOMPLETE
  FAKE_REPORT
  SOP_VIOLATION
  ATTENDANCE
  ATTITUDE
  OTHER
}

enum DisciplinaryEvidenceType {
  PHOTO
  SCREENSHOT
  TASK_REPORT
  NOTE
  FILE
  LINK
}

model DisciplinaryLetter {
  id                       String                   @id @default(uuid()) @db.Uuid
  letterNumber             String                   @unique @map("letter_number") @db.VarChar(50)
  type                     DisciplinaryLetterType
  level                    Int                      @db.SmallInt
  status                   DisciplinaryLetterStatus @default(DRAFT)
  employeeId               String                   @map("employee_id") @db.VarChar(50)
  employeeNameSnapshot     String                   @map("employee_name_snapshot") @db.VarChar(200)
  employeePositionSnapshot String?                  @map("employee_position_snapshot") @db.VarChar(100)
  outletId                 String?                  @map("outlet_id") @db.Uuid
  outletNameSnapshot       String                   @map("outlet_name_snapshot") @db.VarChar(100)
  relatedTaskId            String?                  @map("related_task_id") @db.VarChar(50)
  sourceType               DisciplinarySourceType   @map("source_type")
  incidentDate             DateTime                 @map("incident_date") @db.Date
  createdBy                String                   @map("created_by") @db.VarChar(100)
  createdByName            String?                  @map("created_by_name") @db.VarChar(200)
  approvedBy               String?                  @map("approved_by") @db.VarChar(100)
  approvedByName           String?                  @map("approved_by_name") @db.VarChar(200)
  approvedAt               DateTime?                @map("approved_at") @db.Timestamptz(6)
  sentAt                   DateTime?                @map("sent_at") @db.Timestamptz(6)
  acknowledgedAt           DateTime?                @map("acknowledged_at") @db.Timestamptz(6)
  resolvedAt               DateTime?                @map("resolved_at") @db.Timestamptz(6)
  title                    String                   @db.VarChar(300)
  chronology               String
  violationDetail          String                   @map("violation_detail")
  operationalImpact        String?                  @map("operational_impact")
  correctionInstruction    String                   @map("correction_instruction")
  correctionDeadline       DateTime?                @map("correction_deadline") @db.Date
  sopReference             String?                  @map("sop_reference")
  consequence              String?
  internalNote             String?                  @map("internal_note")
  pdfUrl                   String?                  @map("pdf_url")
  createdAt                DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  evidence DisciplinaryEvidence[]
  events   DisciplinaryEvent[]

  @@index([status], map: "idx_disciplinary_letters_status")
  @@index([employeeId], map: "idx_disciplinary_letters_employee")
  @@index([type, level], map: "idx_disciplinary_letters_type_level")
  @@index([createdAt(sort: Desc)], map: "idx_disciplinary_letters_created")
  @@map("disciplinary_letters")
}

model DisciplinaryEvidence {
  id                   String                   @id @default(uuid()) @db.Uuid
  disciplinaryLetterId String                   @map("disciplinary_letter_id") @db.Uuid
  evidenceType         DisciplinaryEvidenceType @map("evidence_type")
  fileUrl              String?                  @map("file_url")
  textNote             String?                  @map("text_note")
  relatedTaskPhotoId   String?                  @map("related_task_photo_id") @db.VarChar(100)
  createdBy            String                   @map("created_by") @db.VarChar(100)
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  letter DisciplinaryLetter @relation(fields: [disciplinaryLetterId], references: [id], onDelete: Cascade)

  @@index([disciplinaryLetterId], map: "idx_disciplinary_evidence_letter")
  @@map("disciplinary_evidence")
}

model DisciplinaryEvent {
  id                   String                    @id @default(uuid()) @db.Uuid
  disciplinaryLetterId String                    @map("disciplinary_letter_id") @db.Uuid
  action               String                    @db.VarChar(50)
  actorId              String                    @map("actor_id") @db.VarChar(100)
  actorNameSnapshot    String                    @map("actor_name_snapshot") @db.VarChar(200)
  previousStatus       DisciplinaryLetterStatus? @map("previous_status")
  newStatus            DisciplinaryLetterStatus? @map("new_status")
  note                 String?
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  letter DisciplinaryLetter @relation(fields: [disciplinaryLetterId], references: [id], onDelete: Cascade)

  @@index([disciplinaryLetterId, createdAt(sort: Desc)], map: "idx_disciplinary_events_letter")
  @@map("disciplinary_events")
}
