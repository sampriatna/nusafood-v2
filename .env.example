# Database (Supabase PostgreSQL recommended)
DATABASE_URL="postgresql://user:pass@localhost:5432/nusafood_v2"

# Auth
SESSION_SECRET="generate-random-64-char-string"
JWT_EXPIRES_IN="7d"
# Opsional: login owner (username kosong) ala v1
ADMIN_PASSWORD="change-me"

# Storage (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
STORAGE_BUCKET="nusafood-photos"

# WhatsApp (fase awal: tetap GAS)
GAS_WEB_APP_URL="https://script.google.com/macros/s/.../exec"
ADMIN_API_KEY="your-gas-admin-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="2.0.0"

# Cutover / rollback (Sprint 7) — lihat docs/SPRINT7_CUTOVER.md
V1_APP_URL="https://v1.example.com"
EMERGENCY_FALLBACK_V1="false"
# CUTOVER_BASE_URL="http://localhost:3002"

# GAS Fallback (fase 1-3)
GAS_FALLBACK_ENABLED="true"

# Dual-write (fase 2-4 / Sprint 3+)
# false = tulis DB saja (dev lokal tanpa GAS)
# true + PRIMARY=gas = GAS dulu lalu DB (sesuai migrasi fase 2)
DUAL_WRITE_ENABLED="false"
DUAL_WRITE_PRIMARY="gas"

# Auth gate (Sprint 6+). Set false hanya untuk uji terbuka tanpa login.
AUTH_REQUIRED="true"

# Sync
# SYNC_FILE="scripts/fixtures/sample-sync.json"

# Monitoring (optional)
# SENTRY_DSN="https://..."
