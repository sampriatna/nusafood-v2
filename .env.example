# Database (Supabase PostgreSQL recommended)
# Pooler transaction mode (app runtime) — port 6543 + pgbouncer=true
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session/direct (migrations) — port 5432 tanpa pgbouncer
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Auth
SESSION_SECRET="generate-random-64-char-string"
JWT_EXPIRES_IN="7d"
# Opsional: login owner (username kosong) ala v1
ADMIN_PASSWORD="change-me"

# Storage (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
STORAGE_BUCKET="nusafood-photos"

# WhatsApp (fase awal: tetap GAS)
GAS_WEB_APP_URL="https://script.google.com/macros/s/.../exec"
ADMIN_API_KEY="your-gas-admin-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="2.0.0"

# Cutover / rollback (Sprint 7) — lihat docs/SPRINT7_CUTOVER.md
V1_APP_URL="https://v1.example.com"
EMERGENCY_FALLBACK_V1="false"
# CUTOVER_BASE_URL="http://localhost:3002"

# GAS Fallback (fase 1-3)
GAS_FALLBACK_ENABLED="true"

# Dual-write (fase 2-4 / Sprint 3+)
# false = tulis DB saja (dev lokal tanpa GAS)
# true + PRIMARY=gas = GAS dulu lalu DB (sesuai migrasi fase 2)
DUAL_WRITE_ENABLED="false"
DUAL_WRITE_PRIMARY="gas"

# Auth gate (Sprint 6+). Set false hanya untuk uji terbuka tanpa login.
AUTH_REQUIRED="true"

# Sync
# SYNC_FILE="scripts/fixtures/sample-sync.json"
# CHECKLIST_SYNC_FILE="scripts/fixtures/sample-checklist-sync.json"

# Cron (Vercel) — lihat apps/web/vercel.json
CRON_SECRET="generate-random-cron-secret"
# Login rate limit (default 5 req / 60 detik per IP)
# LOGIN_RATE_LIMIT_MAX="5"
# LOGIN_RATE_LIMIT_WINDOW_SEC="60"

# Seed demo users (dev only — set true + ADMIN_PASSWORD untuk reset password demo)
# SEED_DEMO_PASSWORDS="false"
